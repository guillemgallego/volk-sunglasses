---
// index.astro – VOLK Sunglasses homepage (Hawkers+Goodr+Oakley inspired)
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import ProductCard from "../components/ProductCard.astro";
import Footer from "../components/Footer.astro";
import { products, getBestsellers } from "../data/products";

const bestsellers = getBestsellers();
const allInStock = products.filter(p => !p.outOfStock);
const lowStock = products.filter(p => p.stock > 0 && p.stock < 3);

// Homepage catalog preview: only first 12 products. Full catalog on /katalog.
const HOME_CATALOG_LIMIT = 12;
const homeCatalogPreview = products.slice(0, HOME_CATALOG_LIMIT);
const remainingCount = Math.max(0, products.length - HOME_CATALOG_LIMIT);

const BASE = "https://volksunglasses.com";

// Build ItemList schema from all in-stock products
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Каталог VOLK Sunglasses — Поляризационные очки",
  "description": "Российский бренд поляризационных солнцезащитных очков с защитой UV400. Линзы TAC Polarized 3-й категории. Бесплатная доставка по России.",
  "url": `${BASE}/katalog`,
  "numberOfItems": allInStock.length,
  // Slim ListItem: only what's needed for ItemList rich results.
  // Full Product/Offer/shippingDetails schema lives on each product page.
  "itemListElement": allInStock.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `${BASE}/${p.slug}`,
    "name": `VOLK ${p.name}`,
    "image": p.images[0]?.startsWith("http") ? p.images[0] : `${BASE}${p.images[0]}`
  }))
};

// Bestsellers spotlight schema for rich results
const bestsellerSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "@id": `${BASE}/#bestsellers`,
  "name": "Хиты продаж VOLK Sunglasses",
  "url": `${BASE}/#bestsellers`,
  "numberOfItems": bestsellers.length,
  "itemListElement": bestsellers.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `${BASE}/${p.slug}`
  }))
};
---

<BaseLayout
  title="Поляризационные очки VOLK UV400 TAC Polarized | Россия"
  og_title="VOLK — Поляризационные очки UV400 | Россия"
  description="Поляризационные солнцезащитные очки VOLK для спорта, вождения и путешествий. Защита UV400, антибликовые линзы TAC Polarized. Бесплатная доставка по всей России."
  og_description="Очки VOLK: UV400, TAC Polarized, 3-я категория. Для спорта, вождения, путешествий. Бесплатная доставка по России."
>
  <!-- Product catalog schema — helps Google Shopping & rich results -->
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema, null, 0)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(bestsellerSchema, null, 0)}></script>

  <Navbar />
  <main id="main-content">
    <!-- ① HERO ─────────────────────────────────────────────── -->
    <Hero />

    <!-- ① bis — SOCIAL PROOF STRIP (Goodr-style bold review count) ── -->
    <div class="social-proof-strip" aria-label="Отзывы покупателей">
      <div class="sp-count">
        <span class="sp-stars" aria-label="5 звёзд из 5">★★★★★</span>
        <strong class="sp-score">4.9</strong>
        <span class="sp-sep">·</span>
        <span class="sp-total">Более <strong>100 покупателей</strong> доверяют VOLK</span>
      </div>
      <div class="sp-reviews">
        <div class="sp-card">
          <div class="sp-card-stars" aria-hidden="true">★★★★★</div>
          <p class="sp-card-text">«Линзы отличные, бликов ноль. За рулём — небо и земля по сравнению с обычными.»</p>
          <span class="sp-card-author">— Михаил, Москва</span>
        </div>
        <div class="sp-card">
          <div class="sp-card-stars" aria-hidden="true">★★★★★</div>
          <p class="sp-card-text">«Брала HERMITAGE, пришли быстро, упаковка хорошая, качество отличное. Носить удобно!»</p>
          <span class="sp-card-author">— Анна, Санкт-Петербург</span>
        </div>
        <div class="sp-card">
          <div class="sp-card-stars" aria-hidden="true">★★★★★</div>
          <p class="sp-card-text">«TAIGA CLASSIC — уже второй год, ни царапины. Поляризация реально работает на рыбалке.»</p>
          <span class="sp-card-author">— Алексей, Екатеринбург</span>
        </div>
      </div>
    </div>

    <!-- ① ter — MEDIA / PLATFORM LOGOS (press-style social proof) ── -->
    <div class="media-strip" aria-label="Платформы и партнёры">
      <span class="media-strip-label">Нас выбирают</span>
      <div class="media-logos">
        <!-- WildBerries -->
        <a href="https://www.wildberries.ru/brands/2672490-volk-sunglasses" class="media-logo-item" target="_blank" rel="noopener" aria-label="VOLK на WildBerries">
          <svg class="media-logo-svg" viewBox="0 0 120 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <text x="0" y="24" font-family="Arial, sans-serif" font-size="18" font-weight="700" fill="currentColor">Wildberries</text>
          </svg>
          <span class="media-logo-sub">2 600+ заказов</span>
        </a>
        <div class="media-sep" aria-hidden="true"></div>
        <!-- СДЭК -->
        <div class="media-logo-item" aria-label="Доставка СДЭК">
          <svg class="media-logo-svg" viewBox="0 0 80 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <text x="0" y="24" font-family="Arial, sans-serif" font-size="20" font-weight="900" fill="currentColor">СДЭК</text>
          </svg>
          <span class="media-logo-sub">Быстрая доставка</span>
        </div>
        <div class="media-sep" aria-hidden="true"></div>
        <!-- Основан 2019 -->
        <div class="media-logo-item" aria-label="VOLK с 2019 года">
          <svg class="media-logo-svg" viewBox="0 0 100 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <text x="0" y="24" font-family="Arial, sans-serif" font-size="22" font-weight="900" fill="currentColor">С 2019</text>
          </svg>
          <span class="media-logo-sub">Работаем с клиентами</span>
        </div>
        <div class="media-sep" aria-hidden="true"></div>
        <!-- Instagram -->
        <a href="https://www.instagram.com/volk.sunglasses/" class="media-logo-item" target="_blank" rel="noopener" aria-label="VOLK в Instagram">
          <svg class="media-logo-svg" viewBox="0 0 120 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <text x="0" y="24" font-family="Arial, sans-serif" font-size="16" font-weight="700" fill="currentColor">@volk.sunglasses</text>
          </svg>
          <span class="media-logo-sub">Instagram</span>
        </a>
      </div>
    </div>

    <!-- ② TRUST BAR — like Blenders/Goodr/Knockaround ──────── -->
    <div class="trust-bar" aria-label="Гарантии и преимущества">
      <div class="trust-bar-inner">
        <div class="tbar-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <div>
            <span class="tbar-title">Гарантия качества</span>
            <span class="tbar-sub">На каждую пару очков</span>
          </div>
        </div>
        <div class="tbar-divider" aria-hidden="true"></div>
        <div class="tbar-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          <div>
            <span class="tbar-title">Бесплатная доставка</span>
            <span class="tbar-sub">По всей России и СНГ — всегда бесплатно</span>
          </div>
        </div>
        <div class="tbar-divider" aria-hidden="true"></div>
        <div class="tbar-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
          <div>
            <span class="tbar-title">Возврат 14 дней</span>
            <span class="tbar-sub">Без вопросов, без споров</span>
          </div>
        </div>
        <div class="tbar-divider" aria-hidden="true"></div>
        <div class="tbar-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <div>
            <span class="tbar-title">★★★★★ 4.9 из 5</span>
            <span class="tbar-sub">100+ проверенных отзывов</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ③ TICKER BAND ─────────────────────────────────────── -->
    <div class="ticker" aria-hidden="true">
      <div class="marquee-track">
        <div class="marquee-inner">
          {Array.from({ length: 10 }).map(() => (
            <span class="ticker-items">
              <span>🕶 TAIGA</span>
              <span class="ticker-dot">✦</span>
              <span>SIBERIA</span>
              <span class="ticker-dot">✦</span>
              <span>HERMITAGE</span>
              <span class="ticker-dot">✦</span>
              <span>UV400</span>
              <span class="ticker-dot">✦</span>
              <span>ПОЛЯРИЗАЦИЯ</span>
              <span class="ticker-dot">✦</span>
              <span>РОССИЯ</span>
              <span class="ticker-dot">✦</span>
            </span>
          ))}
        </div>
      </div>
    </div>

    <!-- ③ VALUE PROPS (Goodr style icons) ─────────────────── -->
    <section class="props-section" aria-label="Преимущества">
      <div class="container props-grid">
        {[
          {
            icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
            title: "UV400 Защита",
            text: "Блокируем 100% вредных лучей UVA и UVB",
          },
          {
            icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`,
            title: "TAC Polarized",
            text: "Поляризационный фильтр 3-й категории затемнения",
          },
          {
            icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>`,
            title: "Доставка по РФ",
            text: "СДЭК по России, Беларуси и Казахстану",
          },
          {
            icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
            title: "Помощь природе",
            text: "Часть средств от каждой покупки идёт на экологию",
          },
        ].map(p => (
          <div class="prop-card">
            <div class="prop-icon" aria-hidden="true" set:html={p.icon}></div>
            <h3 class="prop-title">{p.title}</h3>
            <p class="prop-text">{p.text}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ④ BESTSELLERS GRID ─────────────────────────────────── -->
    <section class="section" id="bestsellers" aria-label="Хиты продаж">
      <div class="container">
        <header class="section-header">
          <div>
            <span class="eyebrow">Топ продаж</span>
            <h2 class="display-lg" style="margin-top: 0.6rem;">Хиты VOLK ⚡</h2>
          </div>
          <a href="/katalog" class="btn btn-ghost btn-sm section-all-btn" id="sec-bestsellers-all">
            Все модели →
          </a>
        </header>

        <!-- Scarcity alert -->
        {lowStock.length > 0 && (
          <div class="scarcity-bar" role="alert">
            <span class="scarcity-fire animate-firebeat">🔥</span>
            <span>
              <strong>Высокий спрос!</strong>
              &nbsp;{lowStock.length} {lowStock.length === 1 ? "модель заканчивается" : "модели заканчиваются"} — успей купить.
            </span>
          </div>
        )}

        <div class="product-grid">
          {bestsellers.map((p) => (
            <ProductCard product={p} eager={false} />
          ))}
        </div>
      </div>
    </section>

    <!-- ⑤ LIFESTYLE SPLIT ─────────────────────────────────── -->
    <section class="lifestyle-section" aria-label="Философия бренда">
      <div class="lifestyle-left">
        <img
          src="/images/2024-12-Sochi-sportivnie-ochki.jpg"
          alt="VOLK Sunglasses Lifestyle - Премиум поляризация"
          loading="lazy"
          decoding="async"
          class="ls-img"
        />
        <!-- Floating info card -->
        <div class="ls-card glass">
          <span class="label-xs" style="color: var(--color-accent);">Наша миссия</span>
          <p class="ls-card-text">"Качество должно быть доступным"</p>
          <a href="/o-brende" class="btn btn-outline-gold btn-sm" id="lifestyle-about">О бренде</a>
        </div>
      </div>
      <div class="lifestyle-right">
        <div class="ls-text-wrap">
          <span class="eyebrow">Разработаны в России</span>
          <h2 class="display-lg" style="margin-top: 0.75rem; max-width: 520px; font-weight: 900; line-height: 0.95;">
            ДЛЯ ТЕХ,<br />КТО ИГРАЕТ<br /><span style="color: var(--color-accent);">БЕЗ ПРАВИЛ</span>
          </h2>
          <p class="ls-body">
            VOLK — российский бренд поляризационных очков для активных людей, водителей, путешественников.
            Мы используем линзы TAC Polarized и защиту UV400, чтобы ваши глаза были в безопасности при любом освещении.
          </p>
          <ul class="ls-features">
            {[
              "Поляризационные линзы 3-й категории",
              "Защита UV400 от UVA и UVB лучей",
              "Антибликовая технология",
              "Унисекс дизайн — подходит всем",
              "Сверхлёгкая квадратная оправа",
              "Часть прибыли идёт на помощь природе",
            ].map(f => (
              <li class="ls-feature">
                <span class="ls-check" aria-hidden="true">◈</span>
                {f}
              </li>
            ))}
          </ul>
          <a href="/katalog" class="btn btn-gold" id="lifestyle-catalog">
            Выбрать очки
          </a>
        </div>
      </div>
    </section>

    <!-- ⑤b ВЫБЕРИ ПО НАЗНАЧЕНИЮ ──────────────────────────── -->
    <section class="uso-section" aria-label="Выбор очков по назначению">
      <div class="container">
        <header class="section-header">
          <div>
            <span class="eyebrow">Для любой задачи</span>
            <h2 class="display-lg" style="margin-top: 0.6rem;">Выбери по назначению</h2>
          </div>
        </header>
        <div class="uso-grid">
          {[
            {
              icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M14 16H9m10 0h3v-3.15a2 2 0 0 0-.84-1.63L18 10M2 16h2m-2 0v-3.15a2 2 0 0 1 .84-1.63L8 10m0 0V8a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M8 10h8"/></svg>`,
              label: "Для вождения",
              desc: "Поляризация устраняет блики от асфальта и лобового стекла",
              href: "/katalog?uso=driving",
              kw: "очки для вождения"
            },
            {
              icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="3"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>`,
              label: "Для спорта и бега",
              desc: "Сверхлёгкие 11–13 г, не спадают при движении, UV400",
              href: "/katalog?uso=sport",
              kw: "спортивные очки"
            },
            {
              icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><polygon points="3 17 12 3 21 17"/><polyline points="3 17 21 17"/></svg>`,
              label: "Для гор и пляжа",
              desc: "Категория 3 — надёжная защита при ярком высокогорном солнце",
              href: "/katalog?uso=mountain",
              kw: "очки для гор"
            },
            {
              icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
              label: "Для путешествий",
              desc: "Компактный чехол, унисекс дизайн, стильно в любой стране",
              href: "/katalog",
              kw: "очки для путешествий"
            },
          ].map(item => (
            <a href={item.href} class="uso-card" aria-label={item.kw}>
              <div class="uso-icon" aria-hidden="true" set:html={item.icon}></div>
              <h3 class="uso-label">{item.label}</h3>
              <p class="uso-desc">{item.desc}</p>
              <span class="uso-cta">Смотреть модели →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ⑤c SEO TEXT BLOCK ────────────────────────────────── -->
    <section class="seo-text-section" aria-label="О технологии VOLK">
      <div class="container seo-text-inner">
        <div class="seo-text-col">
          <h2 class="seo-text-h2">Поляризационные очки VOLK: технология, которая работает</h2>
          <p>
            Солнцезащитные очки VOLK созданы для тех, кто проводит время активно — за рулём, на воде, в горах или просто на летних улицах города. В основе каждой модели — линзы <strong>TAC Polarized</strong> 3-й категории затемнения, которые поглощают 82–92% видимого света и полностью блокируют ультрафиолет классов UVA и UVB (стандарт <strong>UV400</strong>).
          </p>
          <p>
            Поляризационный фильтр устраняет блики, отражённые от мокрого асфальта, воды и стёкол. Это критично при вождении: горизонтально поляризованный свет, вызывающий ослепляющие отблески, нейтрализуется полностью. Водители отмечают, что изображение становится более контрастным и чётким, а усталость глаз за долгую поездку снижается заметно.
          </p>
          <p>
            Коллекции <strong>TAIGA</strong> и <strong>SIBERIA</strong> — квадратная форма оправы, подходящая большинству форм лица. Сверхлёгкий пластик дужек (11–13 г) не давит на виски даже при многочасовой носке. <strong>HERMITAGE</strong> — классическая круглая форма для городского стиля. Все модели унисекс: идеально как для мужчин, так и для женщин.
          </p>
        </div>
        <div class="seo-text-col">
          <h3 class="seo-text-h3">Что входит в комплект</h3>
          <ul class="seo-text-list">
            <li>Очки с поляризационными линзами TAC Polarized</li>
            <li>Чехол-мешочек из микрофибры (защита и протирка)</li>
            <li>Бесплатная доставка СДЭК по России, Беларуси и Казахстану</li>
            <li>Возможность возврата и обмена в течение 14 дней</li>
          </ul>
          <h3 class="seo-text-h3">Для каких задач подходят</h3>
          <ul class="seo-text-list">
            <li><strong>Вождение</strong> — устраняют блики от дороги и лобового стекла</li>
            <li><strong>Спорт и бег</strong> — лёгкие, не спадают при движении</li>
            <li><strong>Горы и пляж</strong> — категория 3 надёжно защищает при ярком солнце</li>
            <li><strong>Путешествия</strong> — компактный чехол удобен в дороге</li>
