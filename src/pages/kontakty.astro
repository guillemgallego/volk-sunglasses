---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Контакты VOLK Sunglasses — Телефон, Email, Форма связи"
  description="Свяжитесь с VOLK Sunglasses: +7 960 273 70 38, info@volksunglasses.com. Работаем ежедневно 10:00—20:00 (МСК). Быстро отвенаем в WhatsApp."
>
  <Navbar />
  
  <main class="contact-page">
    <!-- Hero Header -->
    <section class="contact-hero">
      <div class="hero-bg">
        <div class="pro-grid-bg"></div>
        <div class="bg-overlay"></div>
      </div>
      <div class="container hero-container">
        <nav class="breadcrumb" aria-label="Хлебные крошки">
          <a href="/">Главная</a> <span class="sep">/</span> <span>Контакты</span>
        </nav>
        <h1 class="contact-h1">Связаться с нами</h1>
        <p class="hero-sub">Мы всегда открыты для общения. Напишите нам, и мы ответим в кратчайшие сроки.</p>
      </div>
    </section>

    <section class="contact-sections container">
      <div class="contact-grid">
        <!-- Info Cards -->
        <div class="info-side">
          <div class="info-card glass" style="--delay: 0.1s">
            <div class="card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            </div>
            <div class="card-body">
              <h3>Телефон / WhatsApp</h3>
              <a href="https://wa.me/79602737038" class="main-link">+7 960 273 70 38</a>
              <p class="sub-text">Ежедневно: 10:00 — 20:00 (МСК)</p>
            </div>
          </div>

          <div class="info-card glass" style="--delay: 0.2s">
            <div class="card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </div>
            <div class="card-body">
              <h3>Электронная почта</h3>
              <a href="mailto:info@volksunglasses.com" class="main-link">info@volksunglasses.com</a>
              <p class="sub-text">Среднее время ответа: 2 часа</p>
            </div>
          </div>

          <div class="info-card glass" style="--delay: 0.3s">
            <div class="card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
            <div class="card-body">
              <h3>Локация</h3>
              <span class="main-link">Санкт-Петербург, Россия</span>
              <p class="sub-text">Работаем по всей стране</p>
            </div>
          </div>

          <div class="social-links-wrap glass" style="--delay: 0.4s">
            <h3>Социальные сети</h3>
            <div class="social-tags">
              <a href="https://vk.com/volksunglasses" class="social-tag" target="_blank" rel="noopener">VKONTAKTE</a>
              <a href="https://t.me/volksunglasses" class="social-tag" target="_blank" rel="noopener">TELEGRAM</a>
              <a href="https://www.instagram.com/volk.sunglasses/" class="social-tag" target="_blank" rel="noopener">INSTAGRAM</a>
            </div>
          </div>
        </div>

        <!-- Form Side -->
        <div class="form-side glass" style="--delay: 0.2s">
          <div class="form-header">
            <h2>Написать напрямую</h2>
            <p>Заполните форму, и наш менеджер свяжется с вами.</p>
          </div>
          <form class="premium-form" action="https://formspree.io/f/mqkopqqj" method="POST">
            <div class="input-row">
              <div class="input-group">
                <input type="text" id="name" name="name" placeholder=" " required />
                <label for="name">Ваше имя</label>
              </div>
              <div class="input-group">
                <input type="email" id="email" name="email" placeholder=" " required />
                <label for="email">Email адрес</label>
              </div>
            </div>
            <div class="input-group">
              <textarea id="message" name="message" placeholder=" " rows="4" required></textarea>
              <label for="message">Ваше сообщение</label>
            </div>
            <button type="submit" class="submit-btn">
              <span>ОТПРАВИТЬ СООБЩЕНИЕ</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>

<style>
.contact-page {
  background: var(--color-volk-black);
  min-height: 100vh;
}

/* Hero Section */
.contact-hero {
  position: relative;
  padding: 120px 0 80px;
  overflow: hidden;
}
.hero-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  background: radial-gradient(circle at top right, rgba(206, 255, 2, 0.15), transparent 60%),
              radial-gradient(circle at bottom left, rgba(206, 255, 2, 0.05), transparent 60%),
              #050505;
}
.pro-grid-bg {
  position: absolute;
  inset: 0;
  background-image: 
    linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
  background-position: center center;
  background-size: 60px 60px;
}
.bg-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, transparent 20%, var(--color-volk-black));
}
.hero-container {
  position: relative;
  z-index: 1;
}
.breadcrumb {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-family: var(--font-body);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--color-volk-muted);
  margin-bottom: 2rem;
}
.breadcrumb a { color: var(--color-volk-white); text-decoration: none; transition: color 0.2s; }
.breadcrumb a:hover { color: var(--color-accent); }
.breadcrumb .sep { color: rgba(255,255,255,0.2); }

.display-lg {
  font-family: var(--font-display);
  font-size: clamp(3rem, 8vw, 6rem);
  line-height: 0.9;
  text-transform: uppercase;
  margin-bottom: 1.5rem;
}
.contact-h1 {
  font-family: var(--font-display);
  font-size: clamp(3rem, 8vw, 6rem);
  line-height: 0.9;
  text-transform: uppercase;
  margin-bottom: 1.5rem;
  color: var(--color-volk-white);
}
.hero-sub {
  font-family: var(--font-body);
  font-size: 1.1rem;
  color: var(--color-volk-muted);
  max-width: 600px;
  line-height: 1.6;
}

/* Grid Layout */
.contact-sections {
  padding: 40px 0 120px;
}
.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 3rem;
  align-items: start;
}

/* Cards */
.glass {
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.05);
  padding: 2.5rem;
  border-radius: 4px;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  animation: slideIn 0.8s backwards;
  animation-delay: var(--delay);
}
@keyframes slideIn {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}
.glass:hover {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(206, 255, 2, 0.2);
  transform: translateY(-5px);
}

/* Info Cards */
.info-side {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}
.info-card {
  display: flex;
  gap: 1.5rem;
  align-items: center;
}
.card-icon {
  width: 56px;
  height: 56px;
  background: var(--color-accent);
  color: #000;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 2px;
}
.card-body h3 {
  font-family: var(--font-heading);
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--color-volk-muted);
  margin-bottom: 0.5rem;
}
.main-link {
  display: block;
  font-family: var(--font-body);
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--color-volk-white);
  text-decoration: none;
  transition: color 0.2s;
}
.main-link:hover { color: var(--color-accent); }
.sub-text {
  font-family: var(--font-body);
  font-size: 0.85rem;
  color: var(--color-volk-subtle);
  margin-top: 0.25rem;
}

/* Social Tags */
.social-links-wrap h3 {
  font-family: var(--font-heading);
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--color-volk-muted);
  margin-bottom: 1.5rem;
}
.social-tags {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
}
.social-tag {
  padding: 0.6rem 1.2rem;
  background: transparent;
  border: 1px solid rgba(255,255,255,0.1);
  color: var(--color-volk-white);
  font-family: var(--font-body);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-decoration: none;
  transition: all 0.3s;
}
.social-tag:hover {
  background: var(--color-volk-white);
  color: #000;
  border-color: var(--color-volk-white);
}

/* Form Side */
.form-side {
  position: sticky;
  top: 100px;
}
.form-header {
  margin-bottom: 3rem;
}
.form-header h2 {
  font-family: var(--font-display);
  font-size: 2.2rem;
  color: var(--color-volk-white);
  margin-bottom: 0.75rem;
}
.form-header p {
  color: var(--color-volk-muted);
  font-family: var(--font-body);
}

.premium-form {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}
.input-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}
.input-group {
  position: relative;
}
.input-group input, .input-group textarea {
  width: 100%;
  background: transparent;
  border: none;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  padding: 0.75rem 0;
  font-family: var(--font-body);
  color: #fff;
  font-size: 1rem;
  outline: none;
  transition: border-color 0.3s;
}
.input-group label {
  position: absolute;
  left: 0;
  top: 0.75rem;
  color: var(--color-volk-subtle);
  font-family: var(--font-body);
  pointer-events: none;
  transition: all 0.3s;
}
.input-group input:focus, .input-group textarea:focus {
  border-color: var(--color-accent);
}
.input-group input:focus ~ label,
.input-group input:not(:placeholder-shown) ~ label,
.input-group textarea:focus ~ label,
.input-group textarea:not(:placeholder-shown) ~ label {
  top: -1.2rem;
  font-size: 0.7rem;
  color: var(--color-accent);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-weight: 700;
}

.submit-btn {
  background: var(--color-accent);
  border: none;
  padding: 1.25rem 2.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
  transition: all 0.3s;
  overflow: hidden;
  position: relative;
}
.submit-btn span {
  font-family: var(--font-body);
  font-weight: 800;
  font-size: 0.9rem;
  letter-spacing: 0.1em;
  z-index: 1;
}
.submit-btn:hover {
  transform: scale(1.02);
  filter: brightness(1.1);
}
.submit-btn::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(255,255,255,0.2);
  transform: translateX(-100%);
  transition: transform 0.4s;
}
.submit-btn:hover::after {
  transform: translateX(0);
}

@media (max-width: 1024px) {
  .contact-grid { grid-template-columns: 1fr; }
  .form-side { position: static; }
}
@media (max-width: 640px) {
  .input-row { grid-template-columns: 1fr; }
  .display-lg { font-size: 3.5rem; }
  .glass { padding: 1.75rem; }
}
</style>
