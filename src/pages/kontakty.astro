---
// kontakty.astro – Contact page
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Контакты VOLK Sunglasses — Связаться с нами"
  description="Свяжитесь с VOLK Sunglasses: телефон, email, Telegram, ВКонтакте. Доставка СДЭК по всей России. Режим работы и адрес для возврата товара."
>
  <Navbar />
  <main class="contacts-main">
    <!-- Header -->
    <section class="contacts-header">
      <div class="contacts-header-inner">
        <span class="eyebrow">Обратная связь</span>
        <h1 class="contacts-title">КОНТАКТЫ</h1>
        <p class="contacts-sub">Мы всегда на связи. Выбери удобный способ.</p>
      </div>
    </section>

    <!-- Contact layout -->
    <div class="contacts-layout">
      <!-- Info column -->
      <div class="contacts-info">
        <div class="contact-block">
          <h2 class="contact-block-title">Служба поддержки</h2>
          <div class="contact-items">
            <div class="contact-item">
              <span class="contact-icon">📞</span>
              <div class="contact-detail">
                <a href="tel:+78001234567" class="contact-link">8 (800) 123-45-67</a>
                <span class="contact-note">Бесплатно по России</span>
                <span class="contact-note">Пн–Пт: 9:00–18:00 МСК</span>
              </div>
            </div>
            <div class="contact-item">
              <span class="contact-icon">✉</span>
              <div class="contact-detail">
                <a href="mailto:info@volksunglasses.com" class="contact-link">info@volksunglasses.com</a>
                <span class="contact-note">Ответим в течение 24 часов</span>
              </div>
            </div>
            <div class="contact-item">
              <span class="contact-icon">💬</span>
              <div class="contact-detail">
                <a href="https://t.me/volksunglasses" class="contact-link" target="_blank" rel="noopener noreferrer">@volksunglasses</a>
                <span class="contact-note">Telegram — отвечаем быстро</span>
              </div>
            </div>
          </div>
        </div>

        <div class="contact-block">
          <h2 class="contact-block-title">Доставка и возврат</h2>
          <div class="delivery-info">
            <div class="delivery-item">
              <span class="delivery-label">Доставка</span>
              <span class="delivery-val">СДЭК по всей России</span>
            </div>
            <div class="delivery-item">
              <span class="delivery-label">Срок</span>
              <span class="delivery-val">2–7 рабочих дней</span>
            </div>
            <div class="delivery-item">
              <span class="delivery-label">Бесплатно</span>
              <span class="delivery-val">при заказе от 5 000 ₽</span>
            </div>
            <div class="delivery-item">
              <span class="delivery-label">Возврат</span>
              <span class="delivery-val">30 дней с момента покупки</span>
            </div>
          </div>
        </div>

        <div class="contact-block">
          <h2 class="contact-block-title">Соцсети</h2>
          <div class="social-links">
            <a href="https://instagram.com/volksunglasses" class="social-contact-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram VOLK">
              <span class="social-contact-icon">◈</span>
              Instagram
            </a>
            <a href="https://t.me/volksunglasses" class="social-contact-link" target="_blank" rel="noopener noreferrer" aria-label="Telegram VOLK">
              <span class="social-contact-icon">◈</span>
              Telegram
            </a>
            <a href="https://vk.com/volksunglasses" class="social-contact-link" target="_blank" rel="noopener noreferrer" aria-label="ВКонтакте VOLK">
              <span class="social-contact-icon">◈</span>
              ВКонтакте
            </a>
          </div>
        </div>
      </div>

      <!-- Form -->
      <div class="contact-form-wrap">
        <h2 class="form-title">Написать нам</h2>
        <p class="form-subtitle">Форма обратной связи. Ответим в течение 24 часов.</p>

        <form class="contact-form" id="contact-form" novalidate>
          <div class="form-group">
            <label class="form-label" for="cf-name">Ваше имя *</label>
            <input
              type="text"
              id="cf-name"
              name="name"
              class="form-input"
              placeholder="Александр"
              required
              autocomplete="given-name"
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="cf-email">Email *</label>
            <input
              type="email"
              id="cf-email"
              name="email"
              class="form-input"
              placeholder="example@mail.ru"
              required
              autocomplete="email"
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="cf-phone">Телефон</label>
            <input
              type="tel"
              id="cf-phone"
              name="phone"
              class="form-input"
              placeholder="+7 (999) 000-00-00"
              autocomplete="tel"
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="cf-subject">Тема</label>
            <select id="cf-subject" name="subject" class="form-select">
              <option value="">Выберите тему</option>
              <option value="order">Вопрос о заказе</option>
              <option value="delivery">Доставка</option>
              <option value="return">Возврат / Обмен</option>
              <option value="warranty">Гарантия</option>
              <option value="wholesale">Оптовые закупки</option>
              <option value="other">Другое</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="cf-message">Сообщение *</label>
            <textarea
              id="cf-message"
              name="message"
              class="form-textarea"
              rows="5"
              placeholder="Расскажите, чем мы можем помочь..."
              required
            ></textarea>
          </div>

          <div class="form-check">
            <input type="checkbox" id="cf-agree" class="form-checkbox" required />
            <label for="cf-agree" class="form-check-label">
              Я согласен с <a href="https://volksunglasses.com/privacy">политикой конфиденциальности</a>
            </label>
          </div>

          <button type="submit" class="btn-primary form-submit" id="contact-submit">
            Отправить сообщение
          </button>

          <div class="form-success hidden" id="form-success">
            <span class="success-icon">✓</span>
            <div>
              <strong>Сообщение отправлено!</strong>
              <p>Свяжемся с вами в течение 24 часов.</p>
            </div>
          </div>
        </form>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .contacts-main { padding-top: 70px; }

  .contacts-header {
    background: #090909;
    border-bottom: 1px solid #111;
  }
  .contacts-header-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 4rem 1.5rem 3rem;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-montserrat);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-volk-accent);
    margin-bottom: 1rem;
  }
  .eyebrow::before {
    content: '';
    display: block;
    width: 30px;
    height: 1px;
    background: var(--color-volk-accent);
  }
  .contacts-title {
    font-family: var(--font-bebas);
    font-size: clamp(4rem, 10vw, 8rem);
    letter-spacing: 0.08em;
    line-height: 0.9;
    color: #f5f5f0;
    margin-bottom: 1rem;
  }
  .contacts-sub {
    font-family: var(--font-inter);
    font-size: 0.9rem;
    color: #555;
  }

  /* Layout */
  .contacts-layout {
    max-width: 1400px;
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem;
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 5rem;
    align-items: start;
  }

  /* Info */
  .contacts-info {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .contact-block { display: flex; flex-direction: column; }
  .contact-block-title {
    font-family: var(--font-bebas);
    font-size: 1.5rem;
    letter-spacing: 0.1em;
    color: #f5f5f0;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #1a1a1a;
  }
  .contact-items {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .contact-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }
  .contact-icon {
    font-size: 1.1rem;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .contact-detail {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .contact-link {
    font-family: var(--font-montserrat);
    font-size: 0.88rem;
    font-weight: 600;
    color: #f5f5f0;
    transition: color 0.2s;
  }
  .contact-link:hover { color: var(--color-volk-accent); }
  .contact-note {
    font-family: var(--font-inter);
    font-size: 0.72rem;
    color: #444;
  }

  .delivery-info {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .delivery-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.65rem 0;
    border-bottom: 1px solid #111;
    gap: 1rem;
  }
  .delivery-label {
    font-family: var(--font-inter);
    font-size: 0.78rem;
    color: #555;
  }
  .delivery-val {
    font-family: var(--font-montserrat);
    font-size: 0.75rem;
    font-weight: 600;
    color: #888;
    text-align: right;
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .social-contact-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-montserrat);
    font-size: 0.8rem;
    font-weight: 600;
    color: #555;
    transition: color 0.2s;
    padding: 0.5rem 0;
  }
  .social-contact-link:hover { color: var(--color-volk-accent); }
  .social-contact-icon {
    color: var(--color-volk-accent);
    font-size: 0.7rem;
  }

  /* Form */
  .contact-form-wrap {
    background: #0d0d0d;
    border: 1px solid #1a1a1a;
    padding: 2.5rem;
  }
  .form-title {
    font-family: var(--font-bebas);
    font-size: 2.5rem;
    letter-spacing: 0.08em;
    color: #f5f5f0;
    margin-bottom: 0.5rem;
  }
  .form-subtitle {
    font-family: var(--font-inter);
    font-size: 0.8rem;
    color: #555;
    margin-bottom: 2rem;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .form-label {
    font-family: var(--font-montserrat);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #666;
  }
  .form-input, .form-select, .form-textarea {
    background: #111;
    border: 1px solid #222;
    color: #f5f5f0;
    font-family: var(--font-inter);
    font-size: 0.85rem;
    padding: 0.8rem 1rem;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
    appearance: none;
  }
  .form-input:focus, .form-select:focus, .form-textarea:focus {
    border-color: var(--color-volk-accent);
  }
  .form-input::placeholder, .form-textarea::placeholder {
    color: #444;
  }
  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }
  .form-check {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
  }
  .form-checkbox {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-top: 2px;
    accent-color: var(--color-volk-accent);
    cursor: pointer;
  }
  .form-check-label {
    font-family: var(--font-inter);
    font-size: 0.75rem;
    color: #555;
    line-height: 1.5;
  }
  .form-check-label a {
    color: var(--color-volk-accent);
    text-decoration: underline;
  }
  .form-submit {
    width: 100%;
    padding: 1rem;
    font-size: 0.78rem;
    margin-top: 0.5rem;
  }
  .form-success {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(39, 174, 96, 0.1);
    border: 1px solid rgba(39, 174, 96, 0.3);
    padding: 1rem;
    margin-top: 0.5rem;
  }
  .form-success.hidden { display: none; }
  .success-icon {
    font-size: 1.5rem;
    color: #5dca85;
  }
  .form-success strong {
    display: block;
    font-family: var(--font-montserrat);
    font-size: 0.85rem;
    font-weight: 700;
    color: #f5f5f0;
    margin-bottom: 2px;
  }
  .form-success p {
    font-family: var(--font-inter);
    font-size: 0.75rem;
    color: #555;
  }

  @media (max-width: 1024px) {
    .contacts-layout { grid-template-columns: 1fr; gap: 3rem; }
  }
  @media (max-width: 640px) {
    .contact-form-wrap { padding: 1.5rem; }
    .contacts-layout { padding: 2rem 1rem; }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const btn = document.getElementById('contact-submit') as HTMLButtonElement;
    btn.textContent = 'Отправляем...';
    btn.style.opacity = '0.7';
    btn.disabled = true;

    // Simulate form submission (replace with actual API call)
    setTimeout(() => {
      form.reset();
      btn.style.display = 'none';
      successMsg?.classList.remove('hidden');
    }, 1200);
  });
</script>
