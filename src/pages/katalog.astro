---
// katalog.astro – Product catalog with Hawkers-style filters
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ProductCard from "../components/ProductCard.astro";
import { products } from "../data/products";

const inStock = products.filter(p => !p.outOfStock);
const outOfStock = products.filter(p => p.outOfStock);
const lowStock = products.filter(p => p.stock > 0 && p.stock < 3);
---

<BaseLayout
  title="Каталог солнцезащитных очков VOLK — Поляризация, UV400 | Цены от 2 350 ₽"
  description="Каталог поляризационных солнцезащитных очков VOLK: TAIGA, SIBERIA, HERMITAGE. Защита UV400, линзы TAC Polarized от 2 350 ₽. Бесплатная доставка по России."
>
  <Navbar />
  <main id="main-content">
    <!-- Header -->
    <section class="cat-header" aria-label="Заголовок каталога">
      <div class="container cat-header-inner">
        <div class="cat-header-text">
          <span class="eyebrow">Коллекция 2026</span>
          <h1 class="display-xl cat-title" style="margin-top: 0.6rem;">КАТАЛОГ</h1>
          <p class="cat-desc">
            Все {products.length} моделей. TAC Polarized UV400. Бесплатная доставка по России.
          </p>
        </div>
      </div>
    </section>

    <!-- Scarcity bar -->
    {lowStock.length > 0 && (
      <div class="scarcity-bar container-wide" role="alert">
        <span class="animate-firebeat">🔥</span>
        <strong>Заканчивается!</strong>
        &nbsp;{lowStock.length} {lowStock.length === 1 ? "модель" : "модели"} с остатком менее 3 штук. Торопись!
      </div>
    )}

    <!-- Filter toolbar -->
    <div class="filter-bar">
      <div class="container filter-bar-inner">
        <!-- Category tabs -->
        <div class="filter-tabs" role="tablist" aria-label="Фильтрация по коллекции">
          {[
            { id: "all",        label: "Все" },
            { id: "TAIGA",      label: "TAIGA" },
            { id: "SIBERIA",    label: "SIBERIA" },
            { id: "HERMITAGE",  label: "HERMITAGE" },
            { id: "ALTAI",      label: "ALTAI" },
            { id: "ELBRUS",     label: "ELBRUS" },
            { id: "SAMARA",     label: "SAMARA" },
            { id: "SOCHI",      label: "SOCHI" },
            { id: "ARCTIC",     label: "ARCTIC (МАСКИ)" },
            { id: "VOLK PACK",  label: "РЮКЗАКИ" },
          ].map((t, i) => (
            <button
              class={`filter-tab ${i === 0 ? "filter-tab--active" : ""}`}
              data-filter={t.id}
              role="tab"
              aria-selected={i === 0}
              id={`tab-${t.id}`}
            >
              {t.label}
            </button>
          ))}
        </div>

        <!-- Sort -->
        <div class="sort-row">
          <label class="sort-label" for="sort-select">Сортировка:</label>
          <select id="sort-select" class="sort-select">
            <option value="default">По умолчанию</option>
            <option value="price-asc">Цена ↑</option>
            <option value="price-desc">Цена ↓</option>
            <option value="rating">Рейтинг</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Grid -->
    <div class="container cat-body">
      <!-- Results info -->
      <div class="results-bar">
        <span class="results-count" id="results-count">
          Показано: <strong>{products.length}</strong> из <strong>{products.length}</strong> моделей
        </span>
        <span class="results-stock">{inStock.length} в наличии · {outOfStock.length} нет в наличии</span>
      </div>

      <div class="product-grid product-grid--4" id="catalog-grid">
        {products.map((p, i) => (
          <div
            class="catalog-item"
            data-category={p.category.toUpperCase()}
            data-price={p.price}
            data-rating={p.rating}
            data-instock={!p.outOfStock}
          >
            <ProductCard product={p} eager={i < 4} />
          </div>
        ))}
      </div>

      <!-- Empty state -->
      <div class="empty-state hidden" id="empty-state">
        <p>🕶 Нет моделей по этому фильтру</p>
        <button class="btn btn-ghost btn-sm" id="reset-filters">Сбросить фильтры</button>
      </div>
    </div>

    <!-- Info banner -->
    <section class="cat-info" aria-label="Информация о бренде">
      <div class="container cat-info-inner">
        <div class="cat-info-block">
          <h2 class="display-md">Почему VOLK?</h2>
          <p class="cat-info-text">
            VOLK — российский бренд поляризационных солнцезащитных очков для активных людей, водителей,
            путешественников и всех, кто ценит комфорт и стиль. Мы используем линзы TAC Polarized 3-й
            категории защиты с UV400 — надёжно защищают от UVA и UVB лучей.
          </p>
        </div>
        <div class="cat-info-grid">
          {[
            { num: "UV400", text: "Полная UV защита" },
            { num: "TAC", text: "Polarized линзы" },
            { num: "4.8★", text: "Средний рейтинг" },
            { num: "🌿", text: "Помогаем природе" },
          ].map(i => (
            <div class="cat-stat">
              <span class="cat-stat-num">{i.num}</span>
              <span class="cat-stat-text">{i.text}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
/* Header */
.cat-header {
  background: var(--color-volk-deep);
  border-bottom: 1px solid var(--color-volk-border);
  overflow: hidden;
}
.cat-header-inner {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  min-height: 220px;
  padding-top: 4rem;
  padding-bottom: 2rem;
}
.cat-title { line-height: 0.88; }
.cat-desc {
  font-family: var(--font-body);
  font-size: 0.85rem;
  color: var(--color-volk-muted);
  margin-top: 0.75rem;
}

/* Scarcity bar */
.scarcity-bar {
  max-width: 1360px;
  margin: 0 auto;
  padding: 0.65rem 2.5rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  background: var(--color-danger-bg);
  border-bottom: 1px solid rgba(224,92,92,0.15);
  font-family: var(--font-body);
  font-size: 0.78rem;
  color: #e07070;
}
.scarcity-bar strong { color: var(--color-volk-white); }

/* Filter bar */
.filter-bar {
  position: sticky;
  top: 64px;
  z-index: 50;
  background: rgba(14,14,14,0.98);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--color-volk-border);
}
.filter-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 0.85rem;
  padding-bottom: 0.85rem;
  gap: 1rem;
  flex-wrap: wrap;
}
.filter-tabs {
  display: flex;
  gap: 0;
}
.filter-tab {
  font-family: var(--font-body);
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-volk-muted);
  background: transparent;
  border: 1px solid var(--color-volk-border);
  border-right: none;
  padding: 0.55rem 1.1rem;
  transition: all 0.2s;
}
.filter-tab:last-child { border-right: 1px solid var(--color-volk-border); }
.filter-tab:hover { color: var(--color-volk-white); background: var(--color-volk-surface); }
.filter-tab--active {
  background: var(--color-accent);
  color: var(--color-volk-black) !important;
  border-color: var(--color-accent);
}

.sort-row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.sort-label {
  font-family: var(--font-body);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-volk-muted);
}
.sort-select {
  background: var(--color-volk-surface);
  border: 1px solid var(--color-volk-border-hi);
  color: var(--color-volk-white);
  font-family: var(--font-body);
  font-size: 0.72rem;
  padding: 0.45rem 0.85rem;
  outline: none;
  cursor: pointer;
  transition: border-color 0.2s;
}
.sort-select:focus { border-color: var(--color-accent); }

/* Content */
.cat-body {
  padding-top: 2rem;
  padding-bottom: 4rem;
}
.results-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1.5rem;
  gap: 1rem;
  flex-wrap: wrap;
}
.results-count {
  font-family: var(--font-body);
  font-size: 0.78rem;
  color: var(--color-volk-muted);
}
.results-count strong { color: var(--color-volk-white); }
.results-stock {
  font-family: var(--font-body);
  font-size: 0.68rem;
  color: var(--color-volk-subtle);
  letter-spacing: 0.06em;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
.product-grid--4 { grid-template-columns: repeat(4, 1fr); }

/* Empty state */
.empty-state {
  text-align: center;
  padding: 5rem 2rem;
  font-family: var(--font-body);
  font-size: 1.1rem;
  color: var(--color-volk-muted);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.25rem;
}

/* Info banner */
.cat-info {
  background: var(--color-volk-deep);
  border-top: 1px solid var(--color-volk-border);
  padding: 4rem 0;
}
.cat-info-inner {
  display: grid;
  grid-template-columns: 1.5fr 1fr;
  gap: 4rem;
  align-items: center;
}
.cat-info-block h2 { margin-bottom: 1rem; }
.cat-info-text {
  font-family: var(--font-body);
  font-size: 0.88rem;
  color: var(--color-volk-muted);
  line-height: 1.85;
}
.cat-info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: var(--color-volk-border);
  border: 1px solid var(--color-volk-border);
}
.cat-stat {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  padding: 1.5rem;
  background: var(--color-volk-surface);
}
.cat-stat-num {
  font-family: var(--font-heading);
  font-size: 1.5rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: var(--color-accent);
}
.cat-stat-text {
  font-family: var(--font-body);
  font-size: 0.68rem;
  color: var(--color-volk-muted);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

@media (max-width: 1100px) {
  .product-grid--4 { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 900px) {
  .cat-header-inner { align-items: center; text-align: center; }
}
@media (max-width: 768px) {
  .product-grid--4 { grid-template-columns: repeat(2, 1fr); }
  .cat-info-inner { grid-template-columns: 1fr; gap: 2.5rem; }
  .filter-bar-inner { flex-direction: column; align-items: flex-start; }
}
@media (max-width: 480px) {
  .product-grid--4 { grid-template-columns: 1fr; }
}
</style>

<script>
  const tabs    = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
  const sortSel = document.getElementById('sort-select') as HTMLSelectElement;
  const items   = document.querySelectorAll<HTMLElement>('.catalog-item');
  const empty   = document.getElementById('empty-state');
  const reset   = document.getElementById('reset-filters');
  const countEl = document.getElementById('results-count');

  let currentFilter = 'all';
  let currentSort   = 'default';

  function apply() {
    let visible = 0;
    const arr = Array.from(items);

    // Filter
    arr.forEach(el => {
      const cat     = el.dataset.category ?? '';
      const show    = currentFilter === 'all' || cat === currentFilter;
      el.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    // Sort
    const grid = document.getElementById('catalog-grid')!;
    const sorted = arr
      .filter(el => el.style.display !== 'none')
      .sort((a, b) => {
        const pa = Number(a.dataset.price);
        const pb = Number(b.dataset.price);
        const ra = Number(a.dataset.rating);
        const rb = Number(b.dataset.rating);
        if (currentSort === 'price-asc')  return pa - pb;
        if (currentSort === 'price-desc') return pb - pa;
        if (currentSort === 'rating')     return rb - ra;
        return 0;
      });

    sorted.forEach(el => grid.appendChild(el));

    // Empty state
    empty?.classList.toggle('hidden', visible > 0);

    // Count
    if (countEl) {
      countEl.innerHTML = `Показано: <strong>${visible}</strong> из <strong>${items.length}</strong> моделей`;
    }
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      currentFilter = tab.dataset.filter ?? 'all';
      tabs.forEach(t => {
        t.classList.remove('filter-tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('filter-tab--active');
      tab.setAttribute('aria-selected', 'true');
      apply();
    });
  });

  sortSel?.addEventListener('change', () => {
    currentSort = sortSel.value;
    apply();
  });

  reset?.addEventListener('click', () => {
    currentFilter = 'all';
    currentSort = 'default';
    sortSel.value = 'default';
    tabs.forEach((t, i) => {
      t.classList.toggle('filter-tab--active', i === 0);
      t.setAttribute('aria-selected', i === 0 ? 'true' : 'false');
    });
    apply();
  });
</script>


