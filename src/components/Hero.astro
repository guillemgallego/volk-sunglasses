---
// Hero.astro – Oakley-inspired brutal hero with real VOLK copy
---

<section class="hero" id="hero" aria-label="Главный баннер">
  <!-- BG image -->
  <div class="hero-bg" aria-hidden="true">
    <picture>
      <source srcset="/hero-volk.webp" type="image/webp" />
      <img
        src="/hero-volk.jpg"
        alt="VOLK поляризационные солнцезащитные очки с UV400 защитой — коллекция 2026"
        class="hero-bg-img"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1920"
        height="1080"
      />
    </picture>
    <div class="hero-gradient"></div>
    <!-- Diagonal sweep cut (like Oakley) -->
    <div class="hero-cut" aria-hidden="true"></div>
  </div>

  <div class="hero-body container">
    <!-- Eyebrow -->
    <div class="hero-eyebrow">
      <span class="eyebrow">★★★★★ &nbsp;4.9 · более 5 000 покупателей</span>
    </div>

    <!-- Headline -->
    <h1 class="hero-headline" id="hero-title">
      <span class="hero-line">ВИДЬ МИР</span>
      <span class="hero-line hero-line--accent text-shimmer" style="color: var(--color-accent); font-weight: 900;">БЕЗ БЛИКОВ.</span>
    </h1>

    <p class="hero-sub">
      TAC Polarized · UV400 · Антиблик.<br />
      Российский бренд с 2019 года. Бесплатная доставка.
    </p>

    <div class="hero-actions">
      <a href="/katalog" class="btn btn-gold btn-lg" id="hero-btn-catalog">
        Смотреть каталог
      </a>
      <a href="/o-brende" class="btn btn-ghost btn-lg" id="hero-btn-brand">
        О бренде
      </a>
    </div>

    <!-- Trust pills — compact, clean -->
    <div class="hero-trust">
      <div class="trust-pill">
        <span class="tp-icon" aria-hidden="true">★</span>
        <span><strong>4.9</strong> / 5 · 5 000+ отзывов</span>
      </div>
      <div class="trust-pill">
        <span class="tp-icon" aria-hidden="true">🛡</span>
        <span>UV400 · TAC Polarized</span>
      </div>
      <div class="trust-pill">
        <span class="tp-icon" aria-hidden="true">🚚</span>
        <span>Бесплатная доставка</span>
      </div>
    </div>
  </div>

  <!-- Scroll cue -->
  <div class="scroll-cue" aria-hidden="true">
    <span>scroll</span>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="scroll-arrow">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </div>
</section>

<style>
.hero {
  position: relative;
  min-height: 80svh;
  display: flex;
  align-items: center;
  overflow: hidden;
}

/* On very wide screens, bound the height so it doesn't zoom in excessively */
@media (min-width: 1400px) {
  .hero {
    min-height: 70svh;
  }
}

/* Background */
.hero-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.hero-bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: 65% center;
}
.hero-gradient {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(110deg,
      rgba(8,8,8,0.95) 0%,
      rgba(8,8,8,0.75) 35%,
      rgba(8,8,8,0.25) 65%,
      rgba(8,8,8,0.05) 100%
    );
}
/* Oakley-style diagonal cut */
.hero-cut {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 130px;
  background: var(--color-volk-black);
  clip-path: polygon(0 100%, 100% 100%, 100% 0);
}

/* Body */
.hero-body {
  position: relative;
  z-index: 2;
  padding-top: 45vh; /* Pushed down slightly below the center logo */
  padding-bottom: 100px;
  width: 100%;
}

.hero-eyebrow {
  margin-bottom: 1.25rem;
}

/* Headline */
.hero-headline {
  display: flex;
  flex-direction: column;
  font-family: var(--font-display);
  font-size: clamp(3rem, 7vw, 6rem);
  line-height: 1.05;
  letter-spacing: -0.02em;
  text-transform: uppercase;
  margin-bottom: 2.5rem;
  max-width: 900px;
  text-shadow: 0 10px 30px rgba(0,0,0,0.5);
  overflow: visible;
  padding-top: 0.1em;
}
.hero-line {
  display: block;
}
.hero-line--accent {
  /* shimmer applied via text-shimmer class in global.css */
}

/* Subtext */
.hero-sub {
  font-family: var(--font-body);
  font-size: clamp(0.95rem, 1.5vw, 1.1rem);
  font-weight: 500;
  color: var(--color-volk-white);
  line-height: 1.5;
  max-width: 500px;
  margin-bottom: 2.5rem;
  text-shadow: 0 2px 4px rgba(0,0,0,0.8);
}

/* CTA row */
.hero-actions {
  display: flex;
  gap: 0.875rem;
  flex-wrap: wrap;
  margin-bottom: 3.5rem;
}

/* Trust pills */
.hero-trust {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  flex-wrap: wrap;
}
.trust-pill {
  display: flex;
  align-items: center;
  gap: 0.45rem;
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 100px;
  padding: 0.45rem 0.9rem;
  font-family: var(--font-body);
  font-size: 0.78rem;
  color: rgba(255,255,255,0.8);
  backdrop-filter: blur(6px);
  white-space: nowrap;
}
.trust-pill strong { color: var(--color-accent); }
.tp-icon { font-size: 0.9rem; }

/* Scroll cue */
.scroll-cue {
  position: absolute;
  bottom: 1.75rem;
  right: 2.5rem;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-body);
  font-size: 0.52rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--color-volk-muted);
  writing-mode: vertical-lr;
}
.scroll-arrow {
  animation: scrollBounce 2s ease-in-out infinite;
  color: var(--color-accent);
  width: 16px;
  height: 16px;
}

/* Mobile adjustments */
@media (max-width: 640px) {
  .hero {
    min-height: 100svh;
  }
  .hero-body {
    padding-top: 38vh;
    padding-bottom: 80px;
  }
  .hero-bg-img {
    object-position: 70% center;
  }
  .hero-actions {
    flex-direction: column;
    gap: 0.75rem;
  }
  .hero-actions .btn { width: 100%; justify-content: center; }
  .scroll-cue { display: none; }
  .hero-cut { height: 60px; }
  .hero-trust { gap: 0.4rem; }
  .trust-pill { font-size: 0.7rem; padding: 0.4rem 0.7rem; }
}
</style>
