---
// Footer.astro – Premium footer with real VOLK contact info
const year = new Date().getFullYear();
---

<footer class="footer" aria-label="Footer VOLK Sunglasses">
  <!-- Marquee ticker -->
  <div class="footer-ticker" aria-hidden="true">
    <div class="marquee-track">
      <div class="marquee-inner">
        {Array.from({ length: 12 }).map(() => (
          <span class="ft-items">
            <span>VOLK SUNGLASSES</span>
            <span class="ft-sep">✦</span>
            <span>РОССИЯ</span>
            <span class="ft-sep">✦</span>
            <span>UV400</span>
            <span class="ft-sep">✦</span>
            <span>TAC POLARIZED</span>
            <span class="ft-sep">✦</span>
            <span>ПОМОЩЬ ПРИРОДЕ</span>
            <span class="ft-sep">✦</span>
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- Main footer -->
  <div class="footer-main">
    <div class="footer-container">
      <!-- Brand col -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="VOLK Sunglasses главная">
          <span class="footer-logo-volk">VOLK</span>
          <span class="footer-logo-sub">SUNGLASSES</span>
        </a>
        <p class="footer-tagline">
          Поляризационные солнцезащитные очки. Разработаны в России. Для спорта, вождения и путешествий.
        </p>
        <div class="footer-social">
          <a href="https://www.instagram.com/volk.sunglasses/" class="social-btn" target="_blank" rel="noopener noreferrer" aria-label="Instagram VOLK">
