---
// Navbar.astro – Hawkers-inspired premium sticky navbar
const links = [
  { href: "/",          label: "Главная"   },
  { href: "/katalog",   label: "Каталог"   },
  { href: "/o-brende",  label: "О бренде"  },
  { href: "/blog",      label: "Блог"      },
  { href: "/kontakty",  label: "Контакты"  },
];
const path = Astro.url.pathname;
---

<!-- Top announcement bar (like Hawkers) -->
<div class="topbar" id="topbar" role="status" aria-label="Акция">
  <div class="topbar-inner">
    <span class="topbar-text">
      🐺 Бесплатная доставка по России и СНГ &nbsp;·&nbsp; 10% скидка на следующий заказ при подписке
    </span>
  </div>
</div>

<header class="navbar" id="navbar" role="banner">
  <div class="navbar-container">
    <!-- Logo -->
    <a href="/" class="logo" aria-label="VOLK Sunglasses — на главную">
      <img src="/images/logo-volk.png" alt="VOLK Sunglasses" class="navbar-logo-img" width="100" height="59" />
    </a>

    <!-- Nav desktop -->
    <nav class="nav-desktop" aria-label="Основная навигация">
      {links.map(l => (
        <a
          href={l.href}
          class={`nav-link ${path === l.href ? "nav-link--active" : ""}`}
          aria-current={path === l.href ? "page" : undefined}
        >
          {l.label}
        </a>
      ))}
    </nav>

    <!-- Actions -->
    <div class="nav-actions">
      <!-- WhatsApp icon -->
      <a href="https://wa.me/79602737038" class="nav-whatsapp" title="WhatsApp" aria-label="Написать в WhatsApp" target="_blank" rel="noopener noreferrer">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </a>
      <!-- Cart icon -->
      <a href="https://api.volksunglasses.com/cart/" class="nav-cart" id="nav-cart" title="Корзина" aria-label="Корзина" target="_blank" rel="noopener noreferrer">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span class="nav-cart-count" id="nav-cart-count" aria-live="polite">0</span>
      </a>
      <a href="/katalog" class="btn btn-gold btn-sm nav-cta" id="nav-cta-btn">
        Купить →
      </a>
      <button id="burger" class="burger-btn" aria-label="Открыть меню" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" role="dialog" aria-label="Мобильное меню" aria-hidden="true">
    <nav aria-label="Мобильная навигация">
      {links.map(l => (
        <a href={l.href} class={`mobile-link ${path === l.href ? "mobile-link--active" : ""}`}>
          {l.label}
          <span class="mobile-link-arrow">→</span>
        </a>
      ))}
    </nav>
    <div class="mobile-cta">
      <a href="/katalog" class="btn btn-gold btn-full">Перейти в каталог</a>
      <div class="mobile-contact">
        <a href="https://wa.me/79602737038" class="mobile-wa" target="_blank" rel="noopener noreferrer">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          +7 960 273 70 38
        </a>
        <a href="mailto:info@volksunglasses.com" class="mobile-email">info@volksunglasses.com</a>
      </div>
    </div>
  </div>
</header>

<style>
/* Topbar */
.topbar {
  background: #ceff02;
  position: relative;
  z-index: 200;
  box-shadow: 0 2px 20px rgba(206,255,2,0.22);
}
.topbar-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0.52rem 1.5rem;
  overflow: hidden;
}
.topbar-text {
  font-family: var(--font-body);
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: #080808;
  white-space: nowrap;
}
@media (max-width: 640px) {
  .topbar-inner {
    padding: 0.45rem 0;
    justify-content: flex-start;
    overflow: hidden;
  }
  .topbar-text {
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    white-space: nowrap;
    animation: topbar-scroll 18s linear infinite;
    padding-left: 100%;
  }
}
@keyframes topbar-scroll {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-100%); }
}

/* Navbar */
.navbar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(8,8,8,0.96);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--color-volk-border);
  transition: border-color 0.3s, background 0.3s;
}
.navbar.scrolled {
  background: rgba(8,8,8,0.99);
  border-bottom-color: var(--color-volk-border-hi);
  box-shadow: 0 4px 24px rgba(0,0,0,0.4);
}
.navbar-container {
  max-width: 1360px;
  margin: 0 auto;
  padding: 0 1.5rem;
  height: 64px;
  display: flex;
  align-items: center;
  gap: 2rem;
}

/* Logo */
.logo {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}
.navbar-logo-img {
  height: 38px;
  width: auto;
  object-fit: contain;
}

/* Desktop nav */
.nav-desktop {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  flex: 1;
  justify-content: center;
}
.nav-link {
  position: relative;
  font-family: var(--font-body);
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-volk-muted);
  padding: 0.4rem 0.9rem;
  transition: color 0.2s;
}
.nav-link::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 50%;
  transform: translateX(-50%) scaleX(0);
  width: 100%;
  height: 1px;
  background: var(--color-accent);
  transition: transform 0.25s ease;
}
.nav-link:hover, .nav-link--active {
  color: var(--color-volk-white);
}
.nav-link:hover::after, .nav-link--active::after {
  transform: translateX(-50%) scaleX(0.7);
}

/* Actions */
.nav-actions {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-shrink: 0;
}
.nav-whatsapp {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  color: var(--color-volk-muted);
  border: 1px solid var(--color-volk-border);
  transition: all 0.2s;
}
.nav-whatsapp:hover {
  color: #25D366;
  border-color: #25D366;
}

/* Cart icon */
.nav-cart {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  color: var(--color-volk-muted);
  border: 1px solid var(--color-volk-border);
  transition: all 0.2s;
  flex-shrink: 0;
}
.nav-cart:hover {
  color: var(--color-accent);
  border-color: var(--color-accent);
}
.nav-cart-count {
  position: absolute;
  top: -6px;
  right: -6px;
  min-width: 18px;
  height: 18px;
  padding: 0 4px;
  background: var(--color-accent);
  color: #080808;
  font-family: var(--font-body);
  font-size: 0.6rem;
  font-weight: 800;
  border-radius: 99px;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  opacity: 0;
  transform: scale(0);
  transition: opacity 0.2s, transform 0.2s;
}
.nav-cart-count.visible {
  opacity: 1;
  transform: scale(1);
}
.nav-cta { display: none; }

/* Burger */
.burger-btn {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 5px;
  width: 38px;
  height: 38px;
  background: transparent;
  border: 1px solid var(--color-volk-border);
  padding: 9px;
}
.burger-btn span {
  display: block;
  width: 100%;
  height: 1px;
  background: var(--color-volk-white);
  transition: all 0.3s ease;
  transform-origin: center;
}
.burger-btn.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
.burger-btn.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.burger-btn.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

/* Mobile menu */
.mobile-menu {
  display: none;
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  border-top: 1px solid var(--color-volk-border);
  background: var(--color-volk-deep);
}
.mobile-menu.open {
  max-height: 600px;
}
.mobile-menu nav {
  padding: 0.5rem 0;
}
.mobile-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-family: var(--font-body);
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-volk-muted);
  padding: 1rem 1.5rem;
  border-bottom: 1px solid var(--color-volk-border);
  transition: all 0.2s;
}
.mobile-link:hover, .mobile-link--active {
  color: var(--color-volk-white);
  background: var(--color-volk-surface);
  padding-left: 1.75rem;
}
.mobile-link-arrow {
  color: var(--color-accent);
  font-size: 0.9rem;
}
.mobile-cta {
  padding: 1.25rem 1.5rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.mobile-contact {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}
.mobile-wa, .mobile-email {
  font-family: var(--font-body);
  font-size: 0.72rem;
  color: var(--color-volk-muted);
  display: flex;
  align-items: center;
  gap: 0.5rem;
  transition: color 0.2s;
}
.mobile-wa:hover { color: #25D366; }
.mobile-email:hover { color: var(--color-accent); }

@media (min-width: 768px) {
  .nav-cta { display: inline-flex; }
  .burger-btn { display: none; }
  .mobile-menu { display: none !important; }
  .navbar-container { padding: 0 2.5rem; }
}
@media (max-width: 767px) {
  .nav-desktop { display: none; }
  .mobile-menu { display: block; }
}
</style>

<script>
  const burger = document.getElementById('burger') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu') as HTMLElement;
  const navbar = document.getElementById('navbar') as HTMLElement;

  burger?.addEventListener('click', () => {
    const open = menu.classList.toggle('open');
    burger.classList.toggle('open', open);
    burger.setAttribute('aria-expanded', String(open));
    menu.setAttribute('aria-hidden', String(!open));
  });

  // Close mobile menu on link click
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menu.classList.remove('open');
      burger?.classList.remove('open');
      burger?.setAttribute('aria-expanded', 'false');
    });
  });

  // Scroll effect
  const onScroll = () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 40);
  };
  window.addEventListener('scroll', onScroll, { passive: true });

  // Cart count — reads WooCommerce cookie set by api.volksunglasses.com
  function updateCartCount() {
    const countEl = document.getElementById('nav-cart-count');
    if (!countEl) return;
    // WooCommerce sets this cookie when items are added to cart
    const match = document.cookie.match(/(?:^|;\s*)woocommerce_items_in_cart=([^;]*)/);
    const count = match ? parseInt(match[1], 10) : 0;
    if (count > 0) {
      countEl.textContent = count > 99 ? '99+' : String(count);
      countEl.classList.add('visible');
    } else {
      countEl.classList.remove('visible');
    }
  }
  updateCartCount();
  // Refresh count when tab gets focus (user may have added items in WC tab)
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') updateCartCount();
  });
</script>
