<script>
  // Gallery switcher
  const thumbs = document.querySelectorAll<HTMLButtonElement>('.gallery-thumb');
  const mainImg = document.getElementById('gallery-img') as HTMLImageElement | null;

  thumbs.forEach(t => {
    t.addEventListener('click', () => {
      const src = t.dataset.src;
      if (!src || !mainImg) return;
      mainImg.style.opacity = '0';
      setTimeout(() => {
        mainImg.src = src;
        mainImg.style.opacity = '1';
      }, 200);
      thumbs.forEach(b => {
        b.classList.remove('gallery-thumb--active');
        b.setAttribute('aria-selected', 'false');
      });
      t.classList.add('gallery-thumb--active');
      t.setAttribute('aria-selected', 'true');
    });
  });

  // Sticky mobile buy bar — shows after scrolling past the CTA
  const stickyBar = document.getElementById('pdp-sticky-bar');
  if (stickyBar) {
    stickyBar.setAttribute('aria-hidden', 'false');
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) {
          stickyBar.classList.add('pdp-sticky-bar--visible');
        } else {
          stickyBar.classList.remove('pdp-sticky-bar--visible');
        }
      },
      { rootMargin: '-60px 0px 0px 0px', threshold: 0 }
    );
    const ctaRef = document.querySelector('.pdp-cta');
    if (ctaRef) observer.observe(ctaRef);
  }
</script>
