---
// produkty/[slug].astro – Premium product page with real VOLK data
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "./Navbar.astro";
import Footer from "./Footer.astro";
import ProductCard from "./ProductCard.astro";
import { products } from "../data/products";
import type { GetStaticPaths } from "astro";

const { product } = Astro.props;
if (!product) return Astro.redirect("/katalog");

const isOutOfStock = product.outOfStock || product.stock === 0;
const isLowStock   = product.stock > 0 && product.stock < 3;
const isMidStock   = product.stock >= 3 && product.stock <= 5;

// Hybrid WooCommerce URLs — backend at api.volksunglasses.com
const WOO_BASE = "https://api.volksunglasses.com";
const checkoutUrl = isOutOfStock
  ? product.originalUrl
  : `${WOO_BASE}/checkout/?add-to-cart=${product.woo_id}`;

const cartUrl = `${WOO_BASE}/cart/?add-to-cart=${product.woo_id}`;

const wildberriesUrl = "https://www.wildberries.ru/brands/2672490-volk-sunglasses";

// Related products (same category, exclude current)
const related = products
  .filter(p => p.slug !== product.slug && !p.outOfStock)
  .slice(0, 4);

// Blog links related to this product
const blogByCategory: Record<string, { slug: string; title: string }[]> = {
  Siberia: [
    { slug: "polyarizacionnye-ochki-kak-vybrat", title: "Поляризационные очки — как выбрать" },
    { slug: "kak-vybrat-solncezashitnye-ochki", title: "Как выбрать солнцезащитные очки?" },
    { slug: "solntsezashitnye-ochki-dlya-voditelei", title: "Солнцезащитные очки для водителей" },
  ],
  Taiga: [
    { slug: "kak-vybrat-solncezashitnye-ochki", title: "Как выбрать солнцезащитные очки?" },
    { slug: "formy-solncezashitnyh-ochkov", title: "Формы солнцезащитных очков" },
    { slug: "luchshye-solntsezashitnye-ochki-dlya-zanyatii-sportom", title: "Лучшие очки для занятий спортом" },
  ],
  Hermitage: [
    { slug: "solntsezashitnye-ochki-krugloi-formy", title: "Солнцезащитные очки круглой формы" },
    { slug: "luchshie-ochki-dlya-muzhchin", title: "Лучшие солнцезащитные очки для мужчин" },
    { slug: "kakie-solntsezashitnye-ochki-mode", title: "Какие солнцезащитные очки в моде?" },
  ],
};

const tagBlogLinks: Record<string, { slug: string; title: string }> = {
  вождение: { slug: "solntsezashitnye-ochki-dlya-voditelei", title: "Очки для водителей" },
  спорт:    { slug: "luchshye-solntsezashitnye-ochki-dlya-zanyatii-sportom", title: "Очки для спорта" },
  пляж:     { slug: "kak-vybrat-solncezashitnye-ochki", title: "Как выбрать солнцезащитные очки?" },
  горы:     { slug: "ochki-dlya-pohodov", title: "Очки для походов" },
  вода:     { slug: "ochki-dlya-vodnyh-vidov-s", title: "Очки для водных видов спорта" },
  жёлтые:  { slug: "ochki-s-zheltymi-linzami", title: "Очки с жёлтыми линзами" },
};

// "Для кого" — 3 arquetipos basados en tags del producto
type Archetype = { icon: string; title: string; desc: string };
const ALL_ARCHETYPES: Record<string, Archetype> = {
  driver: {
    icon: "🚗",
    title: "Водитель в дороге",
    desc: "Поляризация убирает блики с мокрого асфальта и встречных фар. Безопасность на трассе.",
  },
  sport: {
    icon: "🏃",
    title: "Активный спортсмен",
    desc: "Лёгкая оправа, надёжная посадка, защита UV400. Бег, вело, трекинг — очки не подводят.",
  },
  traveler: {
    icon: "🎒",
    title: "Путешественник",
    desc: "Яркое солнце в горах, вода у моря, белый снег — глаза остаются защищёнными в любом свете.",
  },
  city: {
    icon: "🌆",
    title: "Городской стиль",
    desc: "Минимализм и характер. Очки, которые одинаково уместны в офисе, на террасе и вечером в баре.",
  },
  water: {
    icon: "🌊",
    title: "Вода и пляж",
    desc: "Поляризация убирает блики с воды. Видно рыбу под поверхностью и горизонт без засветов.",
  },
};

const pickArchetypes = (tags: string[]): Archetype[] => {
  const picked: Archetype[] = [];
  const tagSet = new Set(tags.map((t) => t.toLowerCase()));
  const has = (...keys: string[]) => keys.some((k) => tagSet.has(k));

  if (has("вождение")) picked.push(ALL_ARCHETYPES.driver);
  if (has("спорт", "активный отдых")) picked.push(ALL_ARCHETYPES.sport);
  if (has("горы", "пляж")) picked.push(ALL_ARCHETYPES.traveler);
  if (has("вода")) picked.push(ALL_ARCHETYPES.water);
  if (has("город", "повседневные", "классика", "гламур")) picked.push(ALL_ARCHETYPES.city);

  // Fallback + dedup + top 3
  const unique = Array.from(new Set(picked));
  while (unique.length < 3) {
    const fallback = [ALL_ARCHETYPES.driver, ALL_ARCHETYPES.traveler, ALL_ARCHETYPES.city].find(
      (a) => !unique.includes(a)
    );
    if (!fallback) break;
    unique.push(fallback);
  }
  return unique.slice(0, 3);
};
const archetypes = pickArchetypes(product.tags);

const catPosts = blogByCategory[product.category] ?? blogByCategory["Taiga"];
const tagExtraPosts = product.tags
  .filter(t => tagBlogLinks[t])
  .map(t => tagBlogLinks[t])
  .filter(p => !catPosts.some(c => c.slug === p.slug))
  .slice(0, 1);
const relatedBlogPosts = [...catPosts, ...tagExtraPosts].slice(0, 3);

// JSON-LD Schema
const BASE = "https://volksunglasses.com";
const productUrl = `${BASE}/${product.slug}`;
const productImages = product.images.map((img: string) =>
  img.startsWith("http") ? img : `${BASE}${img}`
);

const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": productUrl,
  "name": `VOLK ${product.name}`,
  "description": product.description,
  "image": productImages,
  "sku": `VOLK-${product.slug.toUpperCase()}`,
  "mpn": `VOLK-${product.woo_id || product.id}`,
  "brand": {
    "@type": "Brand",
    "@id": `${BASE}/#organization`,
    "name": "VOLK Sunglasses"
  },
  "category": "Солнцезащитные очки / Поляризационные очки",
  "material": "TAC Polarized, пластик",
  "color": product.lens,
  "additionalProperty": [
    { "@type": "PropertyValue", "name": "UV Protection", "value": "UV400" },
    { "@type": "PropertyValue", "name": "Polarization", "value": "TAC Polarized" },
    { "@type": "PropertyValue", "name": "Lens Category", "value": "3" },
  ],
  "offers": {
    "@type": "Offer",
    "price": product.price,
    "priceCurrency": "RUB",
    "availability": isOutOfStock
      ? "https://schema.org/OutOfStock"
      : "https://schema.org/InStock",
    "url": productUrl,
    "seller": {
      "@id": `${BASE}/#organization`,
      "@type": "Organization",
      "name": "VOLK Sunglasses"
    },
    "priceValidUntil": "2026-12-31",
    "shippingDetails": {
      "@type": "OfferShippingDetails",
      "shippingRate": {
        "@type": "MonetaryAmount",
        "value": "0",
        "currency": "RUB"
      },
      "shippingDestination": {
        "@type": "DefinedRegion",
        "addressCountry": "RU"
      },
      "deliveryTime": {
        "@type": "ShippingDeliveryTime",
        "handlingTime": {
          "@type": "QuantitativeValue",
          "minValue": 0,
          "maxValue": 1,
          "unitCode": "DAY"
        },
        "transitTime": {
          "@type": "QuantitativeValue",
          "minValue": 1,
          "maxValue": 7,
          "unitCode": "DAY"
        }
      }
    },
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "applicableCountry": "RU",
      "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
      "merchantReturnDays": 14,
      "returnMethod": "https://schema.org/ReturnByMail",
      "returnFees": "https://schema.org/FreeReturn"
    }
  },
  "aggregateRating": product.reviewCount > 0 ? {
    "@type": "AggregateRating",
    "ratingValue": product.rating,
    "reviewCount": product.reviewCount,
    "bestRating": "5",
    "worstRating": "1"
  } : undefined,
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Главная",
      "item": "https://volksunglasses.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Каталог",
      "item": "https://volksunglasses.com/katalog"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": product.name,
      "item": `https://volksunglasses.com/${product.slug}`
    }
  ]
};

const seoTitle = `${product.name} | Поляризационные очки VOLK Sunglasses`;
const seoDescription = `Купить ${product.name}: ${product.shortDescription}. Цена ${product.priceFormatted}. ${product.outOfStock ? "Следите за появлением в наличии." : "В наличии. "}Поляризация, UV400. Бесплатная доставка по России.`;
---

<BaseLayout title={seoTitle} description={seoDescription} image={product.images[0].startsWith("http") ? product.images[0] : `https://volksunglasses.com${product.images[0]}`} type="product">
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Navbar />

  <main class="pdp-main" id="main-content" itemscope itemtype="https://schema.org/Product">
    <meta itemprop="name" content={product.name} />
    <meta itemprop="description" content={product.description} />

    <!-- ── Breadcrumb ───────────────────────────────────────── -->
    <nav class="breadcrumb" aria-label="Хлебные крошки">
      <div class="container">
        <!-- Breadcrumb HTML (semantic only) — schema via JSON-LD at top of page -->
        <ol class="bc-list">
          <li><a href="/">Главная</a></li>
          <span class="bc-sep" aria-hidden="true">›</span>
          <li><a href="/katalog">Каталог</a></li>
          <span class="bc-sep" aria-hidden="true">›</span>
          <li aria-current="page">{product.name}</li>
        </ol>
      </div>
    </nav>

    <!-- ── Product layout ──────────────────────────────────── -->
    <div class="container pdp-grid">
      <!-- Gallery -->
      <div class="pdp-gallery" id="pdp-gallery">
        <div class="gallery-main" id="gallery-main">
          <img
            src={product.images[0]}
            alt={`${product.name} — поляризационные солнцезащитные очки VOLK`}
            class="gallery-main-img"
            id="gallery-img"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            width="800"
            height="600"
            itemprop="image"
          />
          {isLowStock && (
            <div class="gallery-badge">
              <span class="badge badge-fire animate-firebeat">🔥 Осталось {product.stock} шт.!</span>
            </div>
          )}
          {isOutOfStock && (
            <div class="gallery-oos-overlay">
              <span>Нет в наличии</span>
            </div>
          )}
        </div>

        {product.images.length > 1 && (
          <div class="gallery-thumbs" role="tablist" aria-label="Фотографии товара">
            {product.images.map((img, i) => (
              <button
                class={`gallery-thumb ${i === 0 ? "gallery-thumb--active" : ""}`}
                data-src={img}
                id={`thumb-${i}`}
                role="tab"
                aria-selected={i === 0}
                aria-label={`Фото ${i + 1}`}
              >
                <img
                  src={img}
                  alt={`${product.name} фото ${i + 1}`}
                  loading="lazy"
                  decoding="async"
                  width="140"
                  height="105"
                />
              </button>
            ))}
          </div>
        )}

        <!-- Trust badges (small) -->
        <div class="pdp-trust">
          <div class="trust-badge">
            <span>🚚</span><span>Бесплатная доставка</span>
          </div>
          <div class="trust-badge">
            <span>↩</span><span>Возврат и обмен</span>
          </div>
          <div class="trust-badge">
            <span>🔒</span><span>Безопасная оплата</span>
          </div>
        </div>
      </div>

      <!-- Info panel -->
      <div class="pdp-info">
        <!-- Category pill -->
        <span class="pdp-cat label-xs">{product.category}</span>

        <!-- H1 Title -->
        <h1 class="pdp-title">{product.name}</h1>
        <p class="pdp-tagline">{product.tagline}</p>

        <!-- Rating -->
        <div
          class="pdp-rating"
          itemprop="aggregateRating"
          itemscope
          itemtype="https://schema.org/AggregateRating"
        >
          <div class="rating-stars-lg" role="img" aria-label={`${product.rating} из 5 звёзд`}>
            {Array.from({ length: 5 }, (_, i) => (
              <svg
                width="16" height="16"
                viewBox="0 0 12 12"
                fill={i < Math.floor(product.rating) ? "var(--color-accent)" : "var(--color-volk-border-hi)"}
                aria-hidden="true"
              >
                <path d="M6 0l1.5 4.5H12L8.25 7.5l1.5 4.5L6 9l-3.75 3 1.5-4.5L0 4.5h4.5z"/>
              </svg>
            ))}
          </div>
          <span class="pdp-rating-num" itemprop="ratingValue">{product.rating}</span>
          <a href={`${product.originalUrl}#reviews`} class="pdp-rating-cnt" target="_blank" rel="noopener">
            <span itemprop="reviewCount">{product.reviewCount}</span> отзывов на volksunglasses.com
          </a>
          <meta itemprop="bestRating" content="5" />
          <meta itemprop="worstRating" content="1" />
        </div>

        <hr class="hr-gold" />

        <!-- Price -->
        <div class="pdp-price-block" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
          <span class="pdp-price" itemprop="price" content={String(product.price)}>
            {product.priceFormatted}
          </span>
          <meta itemprop="priceCurrency" content="RUB" />
          <link itemprop="availability" href={isOutOfStock ? "https://schema.org/OutOfStock" : "https://schema.org/InStock"} />
          <link itemprop="itemCondition" href="https://schema.org/NewCondition" />
          <div class="pdp-direct-badge">
            <span class="direct-badge-icon" aria-hidden="true">✓</span>
            <div>
              <strong>Цена напрямую от производителя</strong>
              <span>Без комиссий маркетплейсов · НДС включён</span>
            </div>
          </div>
          <div class="checkout-trust-mini">
            <span class="trust-item">🛡️ Безопасная оплата</span>
            <span class="trust-item">🚚 СДЭК / Почта</span>
            <span class="trust-item">🔄 14 дней на возврат</span>
          </div>
        </div>

        <!-- Stock indicator -->
        <div class={`pdp-stock ${isOutOfStock ? "stock--out" : isLowStock ? "stock--low" : isMidStock ? "stock--mid" : "stock--ok"}`} role="status">
          <span class="stock-dot"></span>
          {isOutOfStock && "Нет в наличии — следите за обновлением"}
          {isLowStock && `🔥 Осталось всего ${product.stock} шт.! Успей купить!`}
          {isMidStock && !isLowStock && `⚡ Заканчивается — ${product.stock} шт. на складе`}
          {!isOutOfStock && !isLowStock && !isMidStock && "✓ В наличии — готов к отправке"}
        </div>

        <!-- Lens info pill -->
        <div class="lens-info">
          <div class="lens-dot" style={`background: ${
            product.lens.includes("голуб") ? "#4fc3f7" :
            product.lens.includes("зелён") ? "#66bb6a" :
            product.lens.includes("роз") ? "#f48fb1" :
            product.lens.includes("жёлт") ? "#ffd54f" :
            product.lens.includes("чёрн") ? "#444" : "#999"
          }`}></div>
          <span class="lens-label">Линзы: {product.lens}</span>
        </div>

        <!-- "Для кого" — 3 arquetipos -->
        <div class="pdp-for-whom" aria-label="Для кого эти очки">
          <p class="pdp-for-whom__title">ДЛЯ КОГО ЭТИ ОЧКИ</p>
          <div class="pdp-for-whom__grid">
            {archetypes.map((a) => (
              <div class="for-whom-card">
                <span class="for-whom-icon" aria-hidden="true">{a.icon}</span>
                <div class="for-whom-body">
                  <strong class="for-whom-title">{a.title}</strong>
                  <span class="for-whom-desc">{a.desc}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Buy CTA -->
        <div class="pdp-cta">
          {isOutOfStock ? (
            <>
              <a href={product.originalUrl} class="btn btn-ghost btn-full btn-lg" target="_blank" rel="noopener" id={`oos-${product.slug}`}>
                ⚠️ Узнать о поступлении на volksunglasses.com
              </a>
              <div class="pdp-cta-divider">
                <span>Или купите на</span>
              </div>
              <a href={wildberriesUrl} class="btn-wb btn-full" target="_blank" rel="noopener noreferrer" id={`wb-${product.slug}`}>
                <svg class="wb-logo" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M20 5C11.72 5 5 11.72 5 20s6.72 15 15 15 15-6.72 15-15S28.28 5 20 5zm0 4.5l3.5 7.5H28l-5.75 4.18 2.2 6.82L20 24.6l-4.45 3.4 2.2-6.82L12 17h4.5L20 9.5z" fill="white"/>
                </svg>
                Купить на Wildberries
                <span class="wb-arrow">→</span>
              </a>
            </>
          ) : (
            <>
              <!-- PRIMARY: Купить сейчас → direct checkout (1 click) -->
              <a
                href={checkoutUrl}
                class="btn-checkout"
                id={`checkout-${product.slug}`}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Купить ${product.name} за ${product.priceFormatted}`}
              >
                <span class="btn-checkout__label">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                  </svg>
                  КУПИТЬ СЕЙЧАС — {product.priceFormatted}
                </span>
                <span class="btn-checkout__sub">Оплата картой · Оформление за 60 сек.</span>
              </a>

              <!-- SECONDARY: В корзину -->
              <a
                href={cartUrl}
                class="btn-addcart"
                id={`cart-${product.slug}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
                </svg>
                В КОРЗИНУ
              </a>

              <div class="pdp-cta-divider"><span>или купите на маркетплейсе</span></div>

              <!-- WILDBERRIES -->
              <a
                href={wildberriesUrl}
                class="btn-wb btn-full"
                target="_blank"
                rel="noopener noreferrer"
                id={`wb-${product.slug}`}
              >
                <svg class="wb-logo" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M20 5C11.72 5 5 11.72 5 20s6.72 15 15 15 15-6.72 15-15S28.28 5 20 5zm0 4.5l3.5 7.5H28l-5.75 4.18 2.2 6.82L20 24.6l-4.45 3.4 2.2-6.82L12 17h4.5L20 9.5z" fill="white"/>
                </svg>
                Купить на Wildberries
                <span class="wb-arrow">→</span>
              </a>

              <!-- Tertiary link -->
              <a href={product.originalUrl} class="pdp-original-link" target="_blank" rel="noopener noreferrer" id="pdp-original">
                Смотреть на volksunglasses.com ↗
              </a>
            </>
          )}
        </div>

        <!-- Guarantee row -->
        <div class="pdp-guarantees">
          {[
            { icon: "🚚", label: "СДЭК по России, Беларуси и Казахстану" },
            { icon: "🔄", label: "Возврат и обмен товара" },
            { icon: "💬", label: "WhatsApp: +7 960 273 70 38" },
            { icon: "🌿", label: "5% с продажи — на помощь природе" },
          ].map(g => (
            <div class="guarantee">
              <span class="guarantee-icon">{g.icon}</span>
              <span class="guarantee-text">{g.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ── STICKY MOBILE BUY BAR ──────────────────────────── -->
    {!isOutOfStock && (
      <div class="pdp-sticky-bar" id="pdp-sticky-bar" aria-hidden="true">
        <div class="pdp-sticky-bar__info">
          <span class="pdp-sticky-bar__name">{product.name}</span>
          <span class="pdp-sticky-bar__price">{product.priceFormatted}</span>
        </div>
        <a href={checkoutUrl} class="pdp-sticky-bar__btn" target="_blank" rel="noopener noreferrer">
          Купить сейчас →
        </a>
      </div>
    )}

    <!-- ── Product Description + Specs ──────────────────────── -->
    <section class="pdp-details" aria-label="Описание и характеристики">
      <div class="container pdp-details-grid">
        <div class="detail-block">
          <h2 class="detail-title">Для кого эта модель?</h2>
          <p class="detail-body">
            {product.slug.includes('siberia') ? 
