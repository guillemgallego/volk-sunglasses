---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "./Navbar.astro";
import Footer from "./Footer.astro";

const { post } = Astro.props;
const { Content } = await render(post);

const seoTitle = `${post.data.title} | Блог VOLK`;
const seoDescription = post.data.excerpt || `Читайте статью "${post.data.title}" в блоге VOLK Sunglasses.`;
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  image={post.data.image || "/images/logo-volk.png"}
  type="article"
>
  <Navbar />
  <main class="post-main" id="main-content">
    <div class="container">
      <nav class="breadcrumb" aria-label="Хлебные крошки">
        <a href="/blog">Блог</a> › <span>{post.data.title}</span>
      </nav>

      <article class="post-article" itemscope itemtype="https://schema.org/BlogPosting">
        <header class="post-header">
          <time
            datetime={post.data.date}
            itemprop="datePublished"
            class="post-date"
          >
            {new Date(post.data.date).toLocaleDateString("ru-RU", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>

          <h1 itemprop="headline" class="post-title display-md">
            {post.data.title}
          </h1>

          <div class="post-author" itemprop="author" itemscope itemtype="https://schema.org/Person">
            <div class="author-image">
              <img src="/images/founder.jpg" alt="Ярослав Кецерас" itemprop="image" />
            </div>
            <div class="author-info">
              <span class="author-label">Автор:</span>
              <span class="author-name" itemprop="name">Ярослав Кецерас</span>
              <p class="author-bio">Основатель VOLK Sunglasses, эксперт по поляризационной оптике. Создаю очки, которые защищают глаза и подчеркивают ваш стиль.</p>
            </div>
          </div>

          {post.data.image && (
            <div class="post-hero-image">
              <img
                src={post.data.image}
                alt={post.data.title}
                itemprop="image"
                loading="eager"
              />
            </div>
          )}
        </header>

        <div class="post-content" itemprop="articleBody">
          <!-- Markdown renders here -->
          <Content />
        </div>
      </article>

      <!-- JSON-LD for combined Schema -->
      <script type="application/ld+json" is:inline define:vars={{ post }}>
        {
          "@context": "https://schema.org",
          "@type": "BlogPosting",
          "headline": post.data.title,
          "image": [post.data.image || "https://volksunglasses.com/images/logo-volk.png"],
          "datePublished": post.data.date,
          "author": [{
            "@type": "Person",
            "name": "Ярослав Кецерас",
            "url": "https://volksunglasses.com/o-brende"
          }],
          "publisher": {
            "@type": "Organization",
            "name": "VOLK Sunglasses",
            "logo": {
              "@type": "ImageObject",
              "url": "https://volksunglasses.com/images/logo-volk.png"
            }
          }
        }
      </script>

      <div class="post-back">
        <a href="/blog" class="btn btn-ghost">← Вернуться в блог</a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
.post-main {
  padding-top: 2rem;
  padding-bottom: 5rem;
}

.breadcrumb {
  font-family: var(--font-body);
  font-size: 0.75rem;
  color: var(--color-volk-muted);
  margin-bottom: 3rem;
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.breadcrumb a {
  color: var(--color-volk-white);
  transition: color 0.2s;
}

.breadcrumb a:hover {
  color: var(--color-accent);
}

.post-article {
  max-width: 800px;
  margin: 0 auto;
}

.post-header {
  margin-bottom: 3rem;
  text-align: center;
}

.post-date {
  font-family: var(--font-body);
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-accent);
  display: block;
  margin-bottom: 1rem;
}

.post-title {
  color: var(--color-volk-white);
  margin-bottom: 2.5rem;
  line-height: 1.1;
}

.post-hero-image {
  margin: 2rem -2rem;
  aspect-ratio: 16/9;
  overflow: hidden;
  border: 1px solid var(--color-volk-border);
}

.post-hero-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Author Byline */
.post-author {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.25rem;
  margin-bottom: 3rem;
  padding: 1.5rem;
  background: var(--color-volk-deep);
  border: 1px solid var(--color-volk-border);
  text-align: left;
}

.author-image {
  width: 70px;
  height: 70px;
  border-radius: 50%;
  overflow: hidden;
  border: 2px solid var(--color-accent);
  flex-shrink: 0;
}

.author-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.author-info {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.author-label {
  font-family: var(--font-body);
  font-size: 0.65rem;
  text-transform: uppercase;
  color: var(--color-accent);
  letter-spacing: 0.1em;
  font-weight: 700;
}

.author-name {
  font-family: var(--font-heading);
  font-size: 1.1rem;
  color: var(--color-volk-white);
}

.author-bio {
  font-family: var(--font-body);
  font-size: 0.8rem;
  color: var(--color-volk-muted);
  line-height: 1.4;
  margin: 0 !important;
}

.post-content {
  font-family: var(--font-body);
  font-size: 1.05rem;
  line-height: 1.8;
  color: #e2e8f0;
}

.post-content :global(h2) {
  font-family: var(--font-heading);
  font-size: 1.75rem;
  color: var(--color-volk-white);
  margin: 3rem 0 1.5rem;
}

.post-content :global(h3) {
  font-family: var(--font-heading);
  font-size: 1.4rem;
  color: var(--color-volk-white);
  margin: 2rem 0 1rem;
}

.post-content :global(p) {
  margin-bottom: 1.5rem;
}

.post-content :global(a) {
  color: var(--color-accent);
  text-decoration: underline;
  text-decoration-color: rgba(206, 255, 2, 0.3);
  text-underline-offset: 4px;
}

.post-content :global(a:hover) {
  text-decoration-color: var(--color-accent);
}

.post-content :global(img) {
  max-width: 100%;
  height: auto;
  display: flex;
  margin: 2.5rem auto;
  border: 1px solid var(--color-volk-border);
}

.post-content :global(ul), .post-content :global(ol) {
  margin-left: 1.5rem;
  margin-bottom: 1.5rem;
}

.post-content :global(li) {
  margin-bottom: 0.5rem;
}

.post-content :global(blockquote) {
  margin: 2.5rem 0;
  padding: 1.5rem;
  border-left: 4px solid var(--color-accent);
  background: var(--color-volk-deep);
  font-style: italic;
  color: var(--color-volk-muted);
}

.post-back {
  max-width: 800px;
  margin: 4rem auto 0;
  padding-top: 2rem;
  border-top: 1px solid var(--color-volk-border);
}

@media (max-width: 640px) {
  .post-hero-image {
    margin: 2rem 0;
  }
}
</style>
